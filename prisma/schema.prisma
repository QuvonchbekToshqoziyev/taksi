generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BotAdmin {
  id       BigInt  @id @default(autoincrement())
  tgId     BigInt  @unique // Telegram user id
  username String?
  fullName String?
  isSuper  Boolean @default(false)

  createdAt      DateTime        @default(now())
  redirectGroups RedirectGroup[]
}

model RedirectGroup {
  id       Int     @id @default(autoincrement())
  chatId   String  @unique
  title    String
  isActive Boolean @default(true)

  deleteOriginal Boolean @default(false)

  addedById BigInt
  addedBy   BotAdmin @relation(fields: [addedById], references: [tgId])

  addedAt   DateTime  @default(now())
  removedAt DateTime?
}

model TargetGroup {
  id       Int     @id @default(autoincrement())
  chatId   String  @unique
  title    String
  isActive Boolean @default(true)

  addedAt   DateTime  @default(now())
  removedAt DateTime?
}

model Keyword {
  id      Int     @id @default(autoincrement())
  phrase  String  @unique
  type    String  // 'client' | 'driver'
  addedAt DateTime @default(now())
}

model Location {
  id        Int        @id @default(autoincrement())
  name      String
  parentId  Int?
  parent    Location?  @relation("LocationTree", fields: [parentId], references: [id])
  children  Location[] @relation("LocationTree")
  isActive  Boolean    @default(true)
  addedAt   DateTime   @default(now())

  @@unique([name, parentId])
}

model AdminLog {
  id            Int      @id @default(autoincrement())
  adminTgId     BigInt
  action        String   // 'add' | 'remove' | 'update'
  targetType    String   // 'location' | 'redirect' | 'target' | 'keyword'
  targetId      String
  details       String?
  previousValue String?
  createdAt     DateTime @default(now())
  restoredAt    DateTime?
}

model RideOrder {
  id         Int      @id @default(autoincrement())
  userTgId   BigInt
  fromName   String
  toName     String
  passengers Int
  phone      String
  status     String   @default("pending") // 'pending' | 'active' | 'completed' | 'cancelled'
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Driver {
  id          Int      @id @default(autoincrement())
  tgId        BigInt   @unique
  fullName    String
  phone       String
  carNumber   String
  carPhotoId  String?  // Telegram file_id for car photo
  status      String   @default("idle") // 'on_road' | 'idle' | 'not_working'
  isApproved  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  posts       DriverPost[]
}

model DriverPost {
  id          Int      @id @default(autoincrement())
  driverId    Int
  driver      Driver   @relation(fields: [driverId], references: [id])
  fromName    String
  toName      String
  seats       Int      // available seats
  price       String?  // optional price info
  note        String?  // optional note
  channelMsgId Int?    // message_id in public channel
  status      String   @default("active") // 'active' | 'closed'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PublicChannel {
  id       Int     @id @default(autoincrement())
  chatId   String  @unique
  title    String
  isActive Boolean @default(true)
  addedAt  DateTime @default(now())
}