generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BotAdmin {
  id       BigInt  @id @default(autoincrement())
  tgId     BigInt  @unique // Telegram user id
  username String?
  fullName String?
  isSuper  Boolean @default(false)

  createdAt      DateTime        @default(now())
  redirectGroups RedirectGroup[]
}

model RedirectGroup {
  id       Int     @id @default(autoincrement())
  chatId   String  @unique
  title    String
  isActive Boolean @default(true)

  deleteOriginal Boolean @default(false)

  addedById BigInt
  addedBy   BotAdmin @relation(fields: [addedById], references: [tgId])  // tgId ga o'zgardi!

  addedAt   DateTime  @default(now())
  removedAt DateTime?
}